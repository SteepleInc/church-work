{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "//#lint": {},
    "//#format:check": {},
    "//#test:e2e": {
      "cache": false
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test:backend": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:cli": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "infra": {
      "cache": false,
      "persistent": true
    },
    "health-check": {
      "cache": false
    },
    "web#dev": {
      "cache": false,
      "dependsOn": ["@church-task/infra-db#health-check", "@church-task/zero#health-check"],
      "persistent": true
    },
    "@church-task/zero#infra": {
      "cache": false,
      "dependsOn": ["@church-task/infra-db#health-check"],
      "persistent": true
    },
    "@church-task/db#dev": {
      "cache": false,
      "dependsOn": ["@church-task/infra-db#health-check"],
      "persistent": true
    },
    "@church-task/zero#health-check": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:setup": {
      "cache": false,
      "persistent": true
    },
    "dev:e2e": {
      "cache": false,
      "persistent": true
    },
    "db:migrate": {
      "cache": false
    }
  }
}
