# GitHub personal access token — the agent uses it to read and manage GitHub Issues
# Create a fine-grained token: https://github.com/settings/personal-access-tokens/new
# Required repository permissions: Contents (Read and write), Pull requests (Read and write),
# Issues (Read and write), and Metadata (Read)
GH_TOKEN=

# Optional: override the PR base branch. Defaults to the GitHub repo default branch.
SANDCASTLE_BASE_BRANCH=

# Optional: merge PRs through GitHub after local pre-publication review and GitHub checks pass.
# Defaults to true. The runner enables GitHub auto-merge without waiting for each PR;
# if repo auto-merge is disabled, it runs `gh pr merge` after checks pass.
# Set false if you want PRs to stay open.
SANDCASTLE_AUTO_MERGE=true

# Optional: wait for the whole PR batch to merge before planning another iteration.
# Defaults to true so newly unblocked and transiently failed issues are picked up in
# the next iteration. Set false for a one-batch run that exits after enabling auto-merge.
SANDCASTLE_WAIT_FOR_MERGES=true

# Optional: after opening a PR, poll GitHub checks and run a local repair agent on failures.
# Defaults to true. The repaired branch is pushed back to the same PR, and GitHub keeps
# owning the final merge.
SANDCASTLE_REPAIR_FAILED_CHECKS=true
SANDCASTLE_MAX_REPAIR_ATTEMPTS=3
# After local verification, retry the enforced sandbox gate with a repair agent.
SANDCASTLE_MAX_LOCAL_GATE_REPAIR_ATTEMPTS=2
SANDCASTLE_CHECK_TIMEOUT_MS=1200000
SANDCASTLE_CHECK_POLL_INTERVAL_MS=30000
SANDCASTLE_MERGE_TIMEOUT_MS=1200000

# The runner probes Docker access and launches Chromium once at startup. When available,
# it gives the sandbox Testcontainers access to the host Docker daemon and enables local
# Playwright E2E verification. This Docker access is appropriate only for trusted agents:
# control of the host daemon can be used to escape the container sandbox.
SANDCASTLE_IMAGE_NAME=sandcastle:church-work
# Set false to disable local container-backed tests. Set true to require the capability
# probe to pass instead of falling back to GitHub CI.
SANDCASTLE_SANDBOX_CAN_RUN_CONTAINER_TESTS=true

# Docker Desktop and OrbStack expose Testcontainers ports through this hostname. The
# runner defaults to it on macOS and Windows; set an explicit address for other runtimes.
# SANDCASTLE_TESTCONTAINERS_HOST_OVERRIDE=host.docker.internal

# The all-around GPT-5.6 Sol agent uses OpenCode with your host config mounted from ~/.config/opencode.
# OpenCode's built-in Codex/OpenAI OAuth auth is mounted from ~/.local/share/opencode/auth.json.
# Run `opencode auth login openai` if auth is missing/expired, then verify:
# `opencode run --model openai/gpt-5.6-sol "hello"`

# The UI Claude Opus 4.8 agent uses OpenCode too, with the @ex-machina/opencode-anthropic-auth plugin from
# ~/.config/opencode/opencode.json and Anthropic OAuth auth mounted from
# ~/.local/share/opencode/auth.json. Verify on the host with:
# `opencode run --model anthropic/claude-opus-4-8 "hello"`
