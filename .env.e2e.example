# Generated/normalized by `bun run test:e2e:setup`.
# Run `bun run test:e2e:local` to set up local Convex and run Playwright.
CONVEX_DEPLOYMENT=local:your-local-deployment-name
CONVEX_URL=http://127.0.0.1:2201
CONVEX_SITE_URL=http://127.0.0.1:2202
VITE_CONVEX_URL=http://127.0.0.1:2201
VITE_CONVEX_SITE_URL=http://127.0.0.1:2202
BETTER_AUTH_SECRET=e2e-local-better-auth-secret-do-not-use-in-production
NODE_ENV=development
SITE_URL=http://127.0.0.1:2101
E2E_SITE_URL=http://127.0.0.1:2101
OTP_CAPTURE_ENABLED=1

# Playwright starts the Vite dev server on this dedicated port by default.
E2E_WEB_PORT=2101

# Optional locally. Required in production for Better Auth Church Invitation emails.
RESEND_API_KEY=re_example
CHURCH_INVITATION_EMAIL_FROM="Church Task <invites@example.com>"
