{
  "name": "church-task",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "backend/*",
      "packages/*"
    ],
    "catalog": {
      "@better-auth/api-key": "~1.6.9",
      "@better-auth/drizzle-adapter": "1.6.19",
      "@confect/core": "^8.0.0",
      "@confect/react": "^8.0.0",
      "@confect/server": "^8.0.0",
      "@t3-oss/env-core": "^0.13.1",
      "@effect/platform": "^0.96.1",
      "@effect/platform-node": "^0.106.0",
      "@effect/sql-drizzle": "0.50.0",
      "@handfish/drizzle-effect": "0.0.17",
      "@rocicorp/zero": "1.6.2",
      "@tanstack/react-start": "1.168.25",
      "@tanstack/start-server-core": "1.168.25",
      "@testcontainers/postgresql": "12.0.2",
      "dotenv": "^17.2.2",
      "drizzle-kit": "0.31.10",
      "drizzle-orm": "0.45.2",
      "drizzle-zero": "0.18.0",
      "effect": "3.21.3",
      "pg": "8.21.0",
      "testcontainers": "12.0.2",
      "typeid-js": "1.2.0",
      "tsx": "4.22.4",
      "vitest": "4.1.9",
      "zod": "^4.1.13",
      "typescript": "^6",
      "next-themes": "^0.4.6",
      "react": "^19.2.6",
      "react-dom": "^19.2.6",
      "convex": "^1.33.1",
      "better-auth": "~1.6.9",
      "@convex-dev/better-auth": "^0.12.2",
      "@convex-dev/polar": "^0.9.1",
      "@types/react": "^19.2.15",
      "@types/react-dom": "^19.2.3",
      "@types/node": "^24.3.0",
      "@types/pg": "8.20.0"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F @church-task/server dev",
    "dev:server:e2e": "turbo -F @church-task/server dev:e2e",
    "dev:setup": "turbo -F @church-task/server dev:setup",
    "convex:wipe": "bun --env-file=.env scripts/wipe-convex-db.ts",
    "test:backend": "turbo -F @church-task/backend-old test:backend",
    "test:cli": "turbo -F @church-task/cli test:cli",
    "test:e2e": "playwright test",
    "test:e2e:onboarding": "CHURCH_TASK_E2E_ONBOARDING_STACK=1 playwright test tests/e2e/onboarding-new-stack.spec.ts --workers=1",
    "test:e2e:teams-workflows": "CHURCH_TASK_E2E_ONBOARDING_STACK=1 playwright test tests/e2e/teams-workflows-new-stack.spec.ts --workers=1",
    "test:e2e:tracer": "CHURCH_TASK_E2E_TRACER=1 playwright test --project=tracer",
    "test:e2e:setup": "bun scripts/setup-e2e.ts",
    "test:e2e:local": "bun scripts/setup-e2e.ts && playwright test",
    "test:task-execution-smoke": "bun scripts/task-execution-smoke.ts",
    "test:task-execution-smoke:full": "bun scripts/task-execution-smoke.ts --require-full",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@church-task/auth": "workspace:*",
    "@church-task/db": "workspace:*",
    "@church-task/domain": "workspace:*",
    "@church-task/env": "workspace:*",
    "@church-task/server": "workspace:*",
    "@church-task/shared": "workspace:*",
    "@church-task/zero": "workspace:*",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.218.0",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/core": "^2.7.1",
    "@opentelemetry/exporter-logs-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/instrumentation": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-logs": "^0.218.0",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/sdk-trace-web": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@superlog/otel-helpers": "^0.1.1",
    "@testcontainers/postgresql": "catalog:",
    "dotenv": "catalog:",
    "jotai": "^2.16.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@church-task/config": "workspace:*",
    "@church-task/test-harness": "workspace:*",
    "@playwright/test": "^1.60.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "tsx": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.13",
  "trustedDependencies": [
    "@rocicorp/zero-sqlite3"
  ]
}
