{
  "name": "church-task",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@better-auth/api-key": "~1.6.9",
      "@confect/core": "^8.0.0",
      "@confect/react": "^8.0.0",
      "@confect/server": "^8.0.0",
      "@effect/platform": "^0.96.1",
      "@effect/platform-node": "^0.106.0",
      "dotenv": "^17.2.2",
      "effect": "^3.21.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "next-themes": "^0.4.6",
      "react": "^19.2.6",
      "react-dom": "^19.2.6",
      "convex": "^1.33.1",
      "better-auth": "~1.6.9",
      "@convex-dev/better-auth": "^0.12.2",
      "@convex-dev/polar": "^0.9.1",
      "@types/react": "^19.2.15",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F @church-task/backend dev",
    "dev:setup": "turbo -F @church-task/backend dev:setup",
    "test:backend": "turbo -F @church-task/backend test:backend",
    "test:cli": "turbo -F @church-task/cli test:cli",
    "test:e2e": "playwright test",
    "test:task-execution-smoke": "bun scripts/task-execution-smoke.ts",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@church-task/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@church-task/config": "workspace:*",
    "@playwright/test": "^1.60.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.13"
}
