{
  "name": "church-work",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "backend/*",
      "packages/*",
      "infra/*"
    ],
    "catalog": {
      "@better-auth/api-key": "1.7.0-beta.6",
      "@better-auth/drizzle-adapter": "1.7.0-beta.6",
      "@t3-oss/env-core": "^0.13.11",
      "@effect/sql-drizzle": "0.50.0",
      "@rocicorp/zero": "1.6.2",
      "@tanstack/react-start": "1.168.26",
      "@tanstack/start-server-core": "1.169.15",
      "@testcontainers/postgresql": "12.0.3",
      "dotenv": "^17.4.2",
      "drizzle-kit": "1.0.0-rc.3",
      "drizzle-orm": "1.0.0-rc.3",
      "drizzle-zero": "1.0.0-beta.0",
      "effect": "4.0.0-beta.84",
      "pg": "8.21.0",
      "testcontainers": "12.0.3",
      "typeid-js": "1.2.0",
      "tsx": "4.22.4",
      "vitest": "4.1.9",
      "zod": "^4.4.3",
      "typescript": "^6.0.3",
      "next-themes": "^0.4.6",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "better-auth": "1.7.0-beta.6",
      "@types/bun": "^1.3.14",
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3",
      "@types/node": "^24.3.0",
      "@types/pg": "8.20.0"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run infra dev --continue",
    "sandcastle": "bunx tsx .sandcastle/main.ts",
    "build": "turbo build",
    "check-types": "turbo check-types --ui=stream",
    "test": "turbo test test:cli --ui=stream",
    "lint": "oxlint",
    "format:check": "oxfmt --check",
    "format": "oxfmt --write",
    "dev:web": "bun --env-file=.env.local turbo -F @church-work/web dev",
    "dev:setup": "turbo -F @church-work/server dev:setup",
    "db:migrate": "turbo -F @church-work/db db:migrate --ui=stream",
    "db:nuke": "bun scripts/nuke-local-db.ts",
    "scheduled:cycle-maintenance": "turbo -F @church-work/server scheduled:cycle-maintenance",
    "test:cli": "turbo -F @church-work/cli test:cli",
    "test:e2e": "bun --env-file=.env.e2e playwright test --workers=1",
    "test:e2e:onboarding": "bun --env-file=.env.e2e playwright test tests/e2e/onboarding-new-stack.spec.ts --workers=1",
    "test:e2e:labels": "bun --env-file=.env.e2e playwright test tests/e2e/labels-new-stack.spec.ts --workers=1",
    "test:e2e:tasks-boards": "bun --env-file=.env.e2e playwright test tests/e2e/tasks-boards-new-stack.spec.ts --workers=1",
    "test:e2e:task-list-scroll": "bun --env-file=.env.e2e playwright test tests/e2e/task-list-scroll-sections-new-stack.spec.ts --workers=1",
    "test:e2e:hover-keybindings": "bun --env-file=.env.e2e playwright test tests/e2e/task-hover-keybindings.spec.ts --workers=1",
    "test:e2e:sub-tasks": "bun --env-file=.env.e2e playwright test tests/e2e/sub-tasks-new-stack.spec.ts --workers=1",
    "test:e2e:task-details-pickers": "bun --env-file=.env.e2e playwright test tests/e2e/task-details-pickers-new-stack.spec.ts --workers=1",
    "test:e2e:task-activity-feed": "bun --env-file=.env.e2e playwright test tests/e2e/task-activity-feed-new-stack.spec.ts --workers=1",
    "test:e2e:templates": "bun --env-file=.env.e2e playwright test tests/e2e/templates-new-stack.spec.ts --workers=1",
    "test:e2e:teams-workflows": "bun --env-file=.env.e2e playwright test tests/e2e/teams-workflows-new-stack.spec.ts --workers=1",
    "test:e2e:invitations": "bun --env-file=.env.e2e playwright test tests/e2e/invitations.spec.ts --workers=1",
    "check": "turbo run //#format:check //#lint check-types test @church-work/cli#test:cli --ui=stream",
    "check:e2e": "turbo run //#format:check //#lint check-types test @church-work/cli#test:cli //#test:e2e --ui=stream"
  },
  "dependencies": {
    "@church-work/auth": "workspace:*",
    "@church-work/db": "workspace:*",
    "@church-work/domain": "workspace:*",
    "@church-work/env": "workspace:*",
    "@church-work/server": "workspace:*",
    "@church-work/shared": "workspace:*",
    "@church-work/zero": "workspace:*",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.218.0",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/core": "^2.7.1",
    "@opentelemetry/exporter-logs-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/instrumentation": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-logs": "^0.218.0",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/sdk-trace-web": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@superlog/otel-helpers": "^0.1.1",
    "@testcontainers/postgresql": "catalog:",
    "dotenv": "catalog:",
    "jotai": "^2.16.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "^0.10.0",
    "@church-work/config": "workspace:*",
    "@church-work/test-harness": "workspace:*",
    "@playwright/test": "^1.60.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "tsx": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.13",
  "trustedDependencies": [
    "@rocicorp/zero-sqlite3"
  ]
}
